# PHP backend environment variables
# Copy this file to .env and export the values in your shell before running
# PHP's built-in dev server, or set them in your hosting panel for production.
# Never commit .env to git.

APP_NAME=budgeting-api
APP_ENV=development
APP_URL=http://localhost:8000

# Database — fill in for Phase 1+
# For production budgeting-app values, check ../../secrets/database.md
# On Hostinger deployed app config, prefer localhost/127.0.0.1 instead of the public server IP.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=budgeting
DB_USER=
DB_PASSWORD=

# Auth — Phase 2
# JWT_SECRET is reserved for future use; bearer tokens are stored in auth_tokens table.
# Set a long random value here if you want to enable JWT signing later.
JWT_SECRET=

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
